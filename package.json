{
  "name": "cher17-keycrm",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run build:history-css && bun ./src/index.ts",
    "build:history-css": "tailwindcss -c ./tailwind.config.cjs -i ./src/history.css -o ./src/history.generated.css --minify",
    "build": "bun run build:history-css && bun build --compile --target bun --outfile server src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^3.4.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/html": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "^1.4.22",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  }
}
